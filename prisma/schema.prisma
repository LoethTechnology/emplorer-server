// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum OAuthProvider {
  LINKEDIN
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ReviewStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  REMOVED
}

enum CommentStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

enum CommentVoteValue {
  HELPFUL
  NOT_HELPFUL
}

model user {
  id                   String           @id @default(cuid())
  email                String?          @unique
  email_verified_at    DateTime?
  display_name         String
  first_name           String?
  last_name            String?
  headline             String?
  avatar_url           String?
  linkedin_profile_url String?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  deleted_at           DateTime?
  oauth_accounts       oauth_account[]
  companies_created    company[]
  company_reviews      company_review[]
  review_critiques     review_critique[]
  review_comments      review_comment[]
  comment_votes        comment_vote[]

  @@index([created_at])
}

model oauth_account {
  id                  String        @id @default(cuid())
  user_id             String
  provider            OAuthProvider
  provider_account_id String
  access_token        String?
  refresh_token       String?
  token_type          String?
  scope               String[]
  expires_at          DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  user                user          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
  @@unique([user_id, provider])
  @@index([user_id])
}

model company {
  id           String           @id @default(cuid())
  creator_id   String
  name         String
  description  String?
  website_url  String?
  domain       String?          @unique
  linkedin_url String?
  logo_url     String?
  headquarters String?
  industry     String?
  status       CompanyStatus    @default(PENDING)
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  creator      user             @relation(fields: [creator_id], references: [id], onDelete: Restrict)
  reviews      company_review[]

  @@index([creator_id])
  @@index([status])
  @@index([name])
}

model company_review {
  id                 String            @id @default(cuid())
  company_id         String
  author_id          String
  body               String
  overall_rating     Int
  employment_context String?
  would_recommend    Boolean?
  status             ReviewStatus      @default(DRAFT)
  published_at       DateTime?
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  company            company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  author             user              @relation(fields: [author_id], references: [id], onDelete: Cascade)
  critiques          review_critique[]
  comments           review_comment[]

  @@index([company_id, status])
  @@index([author_id])
  @@index([published_at])
}

model review_critique {
  id            String         @id @default(cuid())
  review_id     String
  author_id     String
  title         String
  body          String
  rating        Int
  status        ReviewStatus   @default(DRAFT)
  published_at  DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  review        company_review @relation(fields: [review_id], references: [id], onDelete: Cascade)
  author        user           @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([review_id, status])
  @@index([author_id])
  @@index([published_at])
}

model review_comment {
  id                 String           @id @default(cuid())
  review_id          String
  author_id          String
  parent_comment_id  String?
  body               String
  status             CommentStatus    @default(PUBLISHED)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  deleted_at         DateTime?
  review             company_review   @relation(fields: [review_id], references: [id], onDelete: Cascade)
  author             user             @relation(fields: [author_id], references: [id], onDelete: Cascade)
  parent_comment     review_comment?  @relation("ReviewCommentReplies", fields: [parent_comment_id], references: [id], onDelete: Cascade)
  replies            review_comment[] @relation("ReviewCommentReplies")
  votes              comment_vote[]

  @@index([review_id, status])
  @@index([author_id])
  @@index([parent_comment_id])
}

model comment_vote {
  id          String           @id @default(cuid())
  comment_id  String
  user_id     String
  value       CommentVoteValue
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  comment     review_comment   @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user        user             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_id])
  @@index([user_id])
}
